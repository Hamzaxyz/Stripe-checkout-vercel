{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/create-checkout-session",
      "dest": "/api/create-checkout-session"
    },
    {
      "src": "/session-status",
      "dest": "/api/session-status"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
